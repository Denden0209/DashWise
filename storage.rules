// storage.rules
// Firebase Storage security rules.
// Files are stored under users/{uid}/ — only that user can access them.

rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    // User's own files — only they can read/write
    match /users/{uid}/{allPaths=**} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
    }

    // Team shared files
    match /teams/{teamId}/{allPaths=**} {
      allow read:  if request.auth != null &&
        firestore.exists(/databases/(default)/documents/teams/$(teamId)/members/$(request.auth.uid));
      allow write: if request.auth != null &&
        firestore.get(/databases/(default)/documents/teams/$(teamId)/members/$(request.auth.uid)).data.role == "admin";
    }

    // Deny everything else
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
